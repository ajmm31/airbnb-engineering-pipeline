{
  "datasets": [
    {
      "name": "kpi_avg_price",
      "displayName": "KPI: Average Price",
      "queryLines": [
        "SELECT\n",
        "  ROUND(AVG(final_price), 2) as avg_price\n",
        "FROM\n",
        "  silver_airbnb"
      ]
    },
    {
      "name": "kpi_total_properties",
      "displayName": "KPI: Total Properties",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as total_properties\n",
        "FROM\n",
        "  silver_airbnb"
      ]
    },
    {
      "name": "kpi_avg_rating",
      "displayName": "KPI: Average Rating",
      "queryLines": [
        "SELECT\n",
        "  ROUND(AVG(rating), 2) as avg_rating\n",
        "FROM\n",
        "  silver_airbnb"
      ]
    },
    {
      "name": "price_rating_scatter",
      "displayName": "Price vs Rating Analysis",
      "queryLines": [
        "SELECT\n",
        "  final_price,\n",
        "  rating,\n",
        "  property_type,\n",
        "  property_name\n",
        "FROM\n",
        "  silver_airbnb\n",
        "WHERE\n",
        "  final_price IS NOT NULL\n",
        "  AND rating IS NOT NULL"
      ]
    },
    {
      "name": "price_segments",
      "displayName": "Price Segments Analysis",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  gold_price_segments\n",
        "ORDER BY\n",
        "  total_propiedades DESC"
      ]
    },
    {
      "name": "top_locations",
      "displayName": "Top Locations",
      "queryLines": [
        "SELECT\n",
        "  location,\n",
        "  COUNT(*) as property_count,\n",
        "  ROUND(AVG(final_price), 2) as avg_price,\n",
        "  ROUND(MIN(final_price), 2) as min_price,\n",
        "  ROUND(MAX(final_price), 2) as max_price,\n",
        "  ROUND(AVG(rating), 2) as avg_rating,\n",
        "  SUM(review_count) as total_reviews\n",
        "FROM\n",
        "  silver_airbnb\n",
        "WHERE\n",
        "  location IS NOT NULL\n",
        "GROUP BY\n",
        "  location\n",
        "ORDER BY\n",
        "  property_count DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "top_property_types",
      "displayName": "Top Property Types",
      "queryLines": [
        "SELECT\n",
        "  property_type,\n",
        "  COUNT(*) as property_count,\n",
        "  ROUND(AVG(final_price), 2) as avg_price,\n",
        "  ROUND(AVG(rating), 2) as avg_rating\n",
        "FROM\n",
        "  silver_airbnb\n",
        "WHERE\n",
        "  property_type IS NOT NULL\n",
        "GROUP BY\n",
        "  property_type\n",
        "ORDER BY\n",
        "  property_count DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "kpi_total_reviews",
      "displayName": "KPI: Total Reviews",
      "queryLines": [
        "SELECT\n",
        "  SUM(review_count) as total_reviews\n",
        "FROM\n",
        "  silver_airbnb"
      ]
    },
    {
      "name": "top_properties",
      "displayName": "Top Rated Properties",
      "queryLines": [
        "SELECT\n",
        "  property_name,\n",
        "  property_type,\n",
        "  location,\n",
        "  final_price,\n",
        "  rating,\n",
        "  review_count\n",
        "FROM\n",
        "  gold_top_properties\n",
        "ORDER BY\n",
        "  rating DESC,\n",
        "  review_count DESC\n",
        "LIMIT 15"
      ]
    }
  ],
